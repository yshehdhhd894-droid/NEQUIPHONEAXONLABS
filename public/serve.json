{
	"headers": [
		{
			"source": "**/*",
			"headers": [
				{
					"key": "X-Frame-Options",
					"value": "DENY"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "X-Robots-Tag",
					"value": "noindex, nofollow"
				},
				{
					"key": "Cache-Control",
					"value": "no-cache, no-store, must-revalidate"
				},
				{
					"key": "Pragma",
					"value": "no-cache"
				}
			]
		}
	]
}
